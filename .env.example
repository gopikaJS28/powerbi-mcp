# Power BI MCP Server V2 Configuration

# ============================================================
# Cloud Auth — Option A: Username / Password (Easiest)
# Use your Power BI login credentials directly.
# Requires: Premium / PPU workspace with XMLA endpoint enabled.
# Note: Does NOT work if your account has MFA enforced.
# ============================================================
PBI_USERNAME=Gopika.js@exultglobal.com
PBI_PASSWORD=GOP*2803JS

# ============================================================
# Cloud Auth — Option B: Service Principal (Enterprise)
# Requires an Azure AD App Registration.
# Leave blank if using Username/Password above.
# ============================================================
TENANT_ID=your-azure-tenant-id
CLIENT_ID=your-app-client-id
CLIENT_SECRET=your-app-client-secret

# === Logging ===
LOG_LEVEL=INFO

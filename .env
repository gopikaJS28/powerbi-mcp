# Power BI MCP Server — Active Configuration
# ⚠️ Never commit this file to git (it's in .gitignore)

# ============================================================
# AUTH_MODE — controls which authentication method is used
#   device_flow      → Interactive browser login (works with MFA!) ✅
#   service_principal → App-only auth (needs admin setup)
#   (leave blank)    → Falls back to PBI_USERNAME/PBI_PASSWORD
# ============================================================
AUTH_MODE=device_flow

# ============================================================
# Azure AD App Registration (needed for device_flow & service_principal)
# ============================================================
TENANT_ID=7c4bd48c-7217-44bd-b8d6-dacd3736e806
CLIENT_ID=2aeb8078-3f90-48d1-b180-7dd8bf7c27f4
CLIENT_SECRET=50633c95-cfac-4848-8233-10eb48d3ca67

# ============================================================
# Cloud Auth — Username / Password (fallback if AUTH_MODE is blank)
# Note: Does NOT work if MFA is enabled on the account
# ============================================================



# ============================================================
# Feature Flags
# ============================================================
LOG_LEVEL=INFO
ENABLE_PII_DETECTION=true
ENABLE_AUDIT=true
ENABLE_POLICIES=true
